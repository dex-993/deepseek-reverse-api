# DeepSeek AI Reverse API Configuration

# Token Configuration
# Single token or comma-separated tokens
DEEPSEEK_TOKENS=your_token_here

# Or use account pool feature
# Set Authorization: Bearer pool to use token rotation

# Server Configuration
PORT=8000
HOST=0.0.0.0

# Auto delete sessions after completion (true/false)
AUTO_DELETE_SESSION=false

# Token selection strategy: round_robin, random, least_used
TOKEN_STRATEGY=round_robin

# Proxy Configuration
# Vless proxies (comma or newline separated)
VLESS_PROXIES=vless://uuid@host:port?security=tls&type=ws&host=host&path=/path#name

# Or load from file
VLESS_PROXY_FILE=proxies.txt

# HTTP Proxy (fallback if no Vless proxies)
HTTP_PROXY=
HTTPS_PROXY=

# Logging
LOG_LEVEL=INFO
